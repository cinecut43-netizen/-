{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "routes": [
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/og-image.svg", "dest": "/og-image.svg" },
    { "src": "/og-image.png", "dest": "/og-image.png" },
    { "src": "/favicon.ico", "dest": "/logo-v2.png" },
    { "src": "/favicon.svg", "dest": "/logo-v2.png" },
    { "src": "/logo-v2.png", "dest": "/logo-v2.png" },
    { "src": "/logo-v2.png", "dest": "/logo-v2.png" },
    { "src": "/favicon.png", "dest": "/logo-v2.png" },
    { "src": "/api/ai-chat", "dest": "/api/ai-chat.js" },
    { "src": "/api/admin-login", "dest": "/api/admin-login.js" },
    { "src": "/api/admin-verify", "dest": "/api/admin-verify.js" },
    { "src": "/api/send-code", "dest": "/api/send-code.js" },
    { "src": "/api/verify-code", "dest": "/api/verify-code.js" },
    { "src": "/api/check-new-jobs", "dest": "/api/check-new-jobs.js" },
    { "src": "/api/upload-doc", "dest": "/api/upload-doc.js" },
    { "src": "/api/get-doc", "dest": "/api/get-doc.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/chat", "dest": "/chat.html" },
    { "src": "/profile", "dest": "/profile.html" },
    { "src": "/employer", "dest": "/employer.html" },
    { "src": "/map", "dest": "/map.html" },
    { "src": "/wallet", "dest": "/wallet.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/admin-users", "dest": "/admin-users.html" },
    { "src": "/admin-orders", "dest": "/admin-orders.html" },
    { "src": "/admin-workers", "dest": "/admin-workers.html" },
    { "src": "/admin-reviews", "dest": "/admin-reviews.html" },
    { "src": "/admin-complaints", "dest": "/admin-complaints.html" },
    { "src": "/admin-finance", "dest": "/admin-finance.html" },
    { "src": "/admin-settings", "dest": "/admin-settings.html" },
    { "src": "/admin-content", "dest": "/admin-content.html" },
    { "src": "/admin-security", "dest": "/admin-security.html" },
    { "src": "/register", "dest": "/register.html" },
    { "src": "/workers", "dest": "/workers.html" },
    { "src": "/favorites", "dest": "/favorites.html" },
    { "src": "/my-orders", "dest": "/my-orders.html" },
    { "src": "/pro", "dest": "/pro.html" },
    { "src": "/landing", "dest": "/landing.html" },
    { "src": "/onboarding", "dest": "/onboarding.html" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/offer", "dest": "/offer.html" },
    { "src": "/contacts", "dest": "/contacts.html" },
    { "src": "/employer-rules", "dest": "/employer-rules.html" },
    { "src": "/data.js", "dest": "/data.js" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/pwa.js", "dest": "/pwa.js" },
    { "src": "/splash.js", "dest": "/splash.js" },
    { "src": "/mobile.css", "dest": "/mobile.css" },
    { "src": "/icons.js", "dest": "/icons.js" },
    { "src": "/nav.js", "dest": "/nav.js" },
    { "src": "/admin-data.js", "dest": "/admin-data.js" },
    { "src": "/admin-nav.js", "dest": "/admin-nav.js" },
    { "src": "/favicon.svg", "dest": "/favicon.svg" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}



